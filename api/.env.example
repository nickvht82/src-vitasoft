# Core API (@vitasoft/api) environment.
NODE_ENV=development
SERVICE_NAME=api
PORT=3001
LOG_LEVEL=info

# Postgres — shared with @vitasoft/database.
DATABASE_URL="postgresql://vitasoft:vitasoft@localhost:5432/vitasoft?schema=public"

# Redis — session store (better-auth) + BullMQ queues.
REDIS_URL="redis://localhost:6379"

# OpenTelemetry — OTLP endpoint for traces/metrics. Leave unset locally to log
# spans to the console (no collector required); set to a Grafana Cloud / OTLP
# endpoint in staging/prod.
# OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"

# Auth — better-auth session signing secret (min 32 chars). Generate a random
# value; never commit a real secret. In prod this comes from Secret Manager.
BETTER_AUTH_SECRET="dev-only-change-me-0123456789abcdef0123456789abcdef"

# Auth — public base URL better-auth uses for cookies/callbacks. Defaults to
# http://localhost:${PORT}; set explicitly behind a proxy or custom domain.
# BETTER_AUTH_URL="http://localhost:3001"

# Auth — extra credentialed origins (frontends), comma-separated.
# AUTH_TRUSTED_ORIGINS="http://localhost:3000,http://localhost:3100"
